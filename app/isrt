recvExactOneReply :: MonadIO m => Socket -> BS.ByteString -> m (BS.ByteString, BS.ByteString)
recvExactOneReply sock = go
  where
    go acc =
      case splitOneRespFrame acc of
        Just parsed -> pure parsed
        Nothing ->
          recv sock 4096 >>= \case
            Nothing -> pure (acc, mempty)
            Just chunk
              | BS.null chunk -> go acc
              | otherwise     -> go (acc <> chunk)

splitOneRespFrame :: BS.ByteString -> Maybe (BS.ByteString, BS.ByteString)
splitOneRespFrame input =
  case BS.uncons input of
    Nothing -> Nothing
    Just (prefix, _) ->
      case prefix of
        43 -> finishLine -- '+'
        45 -> finishLine -- '-'
        58 -> finishLine -- ':'
        36 -> do         -- '$'
          (hdr, rest1) <- takeRespLine input
          len <- parseBulkLen (BS.drop 1 hdr)
          if BS.length rest1 < len
            then Nothing
            else
              let payload = BS.take len rest1
                  rest2   = BS.drop len rest1
              in Just (hdr <> "\r\n" <> payload, rest2)
        _ -> Nothing
  where
    finishLine = do
      (line, rest) <- takeRespLine input
      pure (line <> "\r\n", rest)

takeRespLine :: BS.ByteString -> Maybe (BS.ByteString, BS.ByteString)
takeRespLine bs =
  let (line, rest) = BS.breakSubstring "\r\n" bs
  in if BS.null rest then Nothing else Just (line, BS.drop 2 rest)

parseBulkLen :: BS.ByteString -> Maybe Int
parseBulkLen bs =
  case BS8.readInt bs of
    Just (n, trailing) | BS.null trailing && n >= 0 -> Just n
    _                                               -> Nothing